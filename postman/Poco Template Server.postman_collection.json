{
  "info": {
    "name": "Car Rental API - New Spec",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get JWT Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Basic dGVzdDp0ZXN0"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/auth",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "auth"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"secret123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"role\": \"customer\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/users/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users", "register"]
            }
          }
        },
        {
          "name": "Search User by Login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/users/search?login=john_doe",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users", "search"],
              "query": [
                {
                  "key": "login",
                  "value": "john_doe"
                }
              ]
            }
          }
        },
        {
          "name": "Search User by Name Mask",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/users/search?name=Jo*&surname=Do*",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users", "search"],
              "query": [
                {
                  "key": "name",
                  "value": "Jo*"
                },
                {
                  "key": "surname",
                  "value": "Do*"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Cars",
      "item": [
        {
          "name": "Get Available Cars",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/cars",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "cars"]
            }
          }
        },
        {
          "name": "Search Cars by Class",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/cars/search?class=luxury",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "cars", "search"],
              "query": [
                {
                  "key": "class",
                  "value": "luxury"
                }
              ]
            }
          }
        },
        {
          "name": "Add New Car (Admin/FleetManager)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Tesla\",\n  \"model\": \"Model 3\",\n  \"licensePlate\": \"TES123\",\n  \"class\": \"luxury\",\n  \"pricePerDay\": 120,\n  \"year\": 2024,\n  \"color\": \"White\",\n  \"features\": [\"Autopilot\", \"GPS\"],\n  \"location\": \"Airport\",\n  \"mileage\": 0,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/cars",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "cars"]
            }
          }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carId\": 5001,\n  \"startDate\": \"2024-05-01T10:00:00\",\n  \"endDate\": \"2024-05-04T10:00:00\",\n  \"insurance\": true,\n  \"paymentId\": \"pay_001\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/rentals?user_id=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "rentals"],
              "query": [
                {
                  "key": "user_id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Get Active Rentals",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/rentals/active?user_id=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "rentals", "active"],
              "query": [
                {
                  "key": "user_id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Get Rental History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/rentals/history?user_id=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "rentals", "history"],
              "query": [
                {
                  "key": "user_id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Complete Rental Early",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/rentals/8001/complete?user_id=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "rentals", "8001", "complete"],
              "query": [
                {
                  "key": "user_id",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}